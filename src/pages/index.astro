---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrustBar from '../components/TrustBar.astro';
import CTABand from '../components/CTABand.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import MultiStepForm from '../components/MultiStepForm.astro';

const title = 'Cabinet Refinishing & Home Refresh for Boston Condo Owners | Jerry & Co.';
const description = 'Factory-grade 2K polyurethane cabinet refinishing and bathroom refresh for condo owners across the Greater Boston ICC zone. HOA-compliant, low-VOC, done in 2–5 days. MA HIC #208336.';
---

<Base title={title} description={description}>
  <Header />

  <!-- ===== HERO ===== -->
  <HeroCarousel />

  <!-- ===== TRUST BAR ===== -->
  <TrustBar />

  <!-- ===== CONDO-READY STRIP ===== -->
  <div class="condo-strip">
    <div class="wrap">
      <div class="condo-card">
        <div class="condo-strip-grid">
          <div class="condo-strip-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m5 4a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>HOA documentation provided on request</span>
          </div>
          <div class="condo-strip-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Low-VOC, neighbor-safe process</span>
          </div>
          <div class="condo-strip-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 6l4-4 4 4"/><path d="M12 2v10.5"/><rect x="3" y="13" width="18" height="8" rx="2"/></svg>
            <span>Elevator &amp; building-access coordination included</span>
          </div>
        </div>
        <h3 class="condo-card-sub">We've navigated condo boards, building managers, and neighbor scheduling across the ICC zone for 7 years.</h3>
      </div>
    </div>
  </div>

  <!-- ===== SERVICES ===== -->
  <section id="services">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Service portfolio</p>
        <h2>Refresh and renovation, organized by the work it actually takes.</h2>
        <p class="section-lede-center">Every project starts the same way — a free video walkthrough and a three-tier proposal. Cabinet refinishing is our focus this season.</p>
      </div>
      <div class="services-grid">
        <div class="service-card featured" id="cabinet-feature">
          <div class="card-body">
            <h3>Cabinet refinishing</h3>
            <p class="price">$1,800 – $9,500</p>
            <p>Factory-grade 2K polyurethane spray finish on existing cabinet boxes — the look of new cabinets, the cost of paint. No demo, no dumpster, no elevator damage — done in 2–5 days.</p>
            <p class="tag">2–5 days · highest-margin craft differentiator</p>
          </div>
          <div class="card-badge-col">
            <span class="badge-featured">Featured this season</span>
          </div>
        </div>
        <div class="service-card">
          <h3>Gut-free bathroom refresh</h3>
          <p class="price">$2,800 – $6,500</p>
          <p>New tile, fixtures, and paint without demo. Gut-free refresh that meets condo renovation bylaws — no permit triggers in most ICC buildings.</p>
          <p class="tag">2–5 days · pairs well with cabinet refinishing</p>
        </div>
        <div class="service-card">
          <h3>Interior painting &amp; refresh</h3>
          <p class="price">$1,400 – $6,500</p>
          <p>Interior painting &amp; refresh — all work contained within your unit. Lead-safe, low-VOC, finished to a standard that holds up.</p>
          <p class="tag">1–4 days · most flexible scheduling</p>
        </div>
        <div class="service-card">
          <h3>Full bathroom renovation</h3>
          <p class="price">$6,500 – $18,000</p>
          <p>Complete gut renovation — subfloor, waterproofing, tile, and finish. May require building board approval — we help you navigate the documentation.</p>
          <p class="tag">5–12 days · written contract per MA law</p>
        </div>
        <div class="service-card">
          <h3>Multi-unit &amp; building refresh</h3>
          <p class="price">Custom pricing</p>
          <p>Coordinated refresh for property managers, landlords, and building owners across multiple units. Scheduled around tenant occupancy and building rules.</p>
          <p class="tag">Contact for scope &amp; timeline</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section class="process-band" id="process">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">How it works</p>
        <h2>The Jerry &amp; Co. factory-finish process</h2>
        <p>Every cabinet refinishing project follows the same five stages — no surprises, no guesswork.</p>
      </div>
      <div class="process-list">
        <div class="process-step">
          <div class="process-num">01</div>
          <h3>Video walkthrough</h3>
          <p>A 20-minute video call gets us a line-item estimate the same day — no waiting on a site visit. We also gather building access requirements, elevator reservation windows, and HOA documentation needs at this stage.</p>
        </div>
        <div class="process-step">
          <div class="process-num">02</div>
          <h3>Prep &amp; containment</h3>
          <p>Fully sealed dust containment within your unit. All equipment staged within your unit — no lobby or hallway storage. Cabinets are removed, labeled, and your kitchen is fully masked.</p>
        </div>
        <div class="process-step">
          <div class="process-num">03</div>
          <h3>Hand sand &amp; repair</h3>
          <p>Hand-sanding only — no loud power tools that travel through condo walls. Every surface is sanded and any dents, gaps, or chips are filled and leveled.</p>
        </div>
        <div class="process-step">
          <div class="process-num">04</div>
          <h3>2K spray finish</h3>
          <p>Low-VOC formula — safe for shared ventilation systems common in multi-unit buildings. A factory-grade polyurethane finish, sprayed in a controlled environment for a smooth, durable result.</p>
        </div>
        <div class="process-step">
          <div class="process-num">05</div>
          <h3>Cure &amp; walkthrough</h3>
          <p>Doors cure, hardware is reinstalled, and we walk the finished space with you. Final walkthrough includes elevator condition check and hallway inspection before we leave.</p>
        </div>
      </div>
      <div class="process-link-row"><a href="/our-process/" class="btn btn-outline" data-ph-event="cta_clicked" data-ph-label="process_see_full">See our full process →</a></div>
    </div>
  </section>

  <!-- ===== GALLERY ===== -->
  <section id="gallery">
    <div class="wrap">
      <div class="section-head left">
        <p class="eyebrow">Recent work</p>
        <h2>Before &amp; after, by project type</h2>
        <p class="section-lede">Real transformations in Greater Boston condos, triple-deckers, and multi-family units. Filter by service to see results from across the ICC zone.</p>
      </div>

      <!-- Gallery island stub — replaced with GalleryGrid.astro in Phase 5 -->
      <div class="filter-row" role="group" aria-label="Filter gallery by project type">
        <button class="filter-btn active" data-filter="all">All projects</button>
        <button class="filter-btn" data-filter="cabinet">Cabinet refinishing</button>
        <button class="filter-btn" data-filter="bathroom">Bathroom refresh</button>
        <button class="filter-btn" data-filter="painting">Painting</button>
        <button class="filter-btn" data-filter="kitchen">Kitchen</button>
        <button class="filter-btn" data-filter="condo">Condo &amp; multi-unit</button>
      </div>
      <div class="gallery-grid" id="galleryGrid">
        <div class="gallery-item" data-cat="cabinet">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="g-label">Cabinet refinishing</span>
          <span class="g-sub">Somerville — condo unit, deep forest green</span>
        </div>
        <div class="gallery-item" data-cat="bathroom">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="g-label">Bathroom refresh</span>
          <span class="g-sub">Cambridge — triple-decker, gut-free update</span>
        </div>
        <div class="gallery-item" data-cat="painting">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="g-label">Interior painting</span>
          <span class="g-sub">Arlington — condo pre-listing refresh</span>
        </div>
        <div class="gallery-item" data-cat="cabinet condo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="g-label">Cabinet refinishing</span>
          <span class="g-sub">Medford — condo conversion, bone white</span>
        </div>
        <div class="gallery-item" data-cat="cabinet">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="g-label">Cabinet refinishing</span>
          <span class="g-sub">Malden — 3-unit multi-family turnover</span>
        </div>
        <div class="gallery-item" data-cat="bathroom condo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="g-label">Bathroom refresh</span>
          <span class="g-sub">Everett — condo board-approved update</span>
        </div>
        <div class="gallery-item" data-cat="painting">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="g-label">Interior painting</span>
          <span class="g-sub">Woburn — owner-occupied colonial refresh</span>
        </div>
        <div class="gallery-item" data-cat="kitchen condo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
          <span class="g-label">Kitchen refresh</span>
          <span class="g-sub">Winchester — cabinets + paint bundle</span>
        </div>
      </div>
      <div class="gallery-link-row"><a href="/gallery/" class="btn btn-outline-dark" data-ph-event="cta_clicked" data-ph-label="gallery_view_full">View full gallery →</a></div>
    </div>
  </section>

  <!-- ===== SERVICE AREA ===== -->
  <section id="area" class="area-section">
    <div class="wrap area-grid">
      <div>
        <p class="eyebrow">Where we work</p>
        <h2>Home to Greater Boston's highest density of condos, triple-deckers, and condo conversions — the buildings we know best.</h2>
        <p class="section-lede">Somerville &amp; Cambridge — triple-decker conversions, HOA-managed condo buildings. Arlington &amp; Winchester — larger unit condos and owner-renovated colonials.</p>
        <div class="chip-group">
          <a href="/cabinet-refinishing-medford/" class="chip chip-primary">Medford</a>
          <a href="/cabinet-refinishing-malden/" class="chip chip-primary">Malden</a>
          <a href="/cabinet-refinishing-everett/" class="chip chip-primary">Everett</a>
          <a href="/cabinet-refinishing-arlington/" class="chip chip-primary">Arlington</a>
          <a href="/cabinet-refinishing-somerville/" class="chip chip-primary">Somerville</a>
          <a href="/cabinet-refinishing-cambridge/" class="chip chip-primary">Cambridge</a>
          <a href="/cabinet-refinishing-woburn/" class="chip chip-primary">Woburn</a>
          <a href="/cabinet-refinishing-winchester/" class="chip chip-primary">Winchester</a>
        </div>
        <p class="area-note">Locally owned and operated — serving the ICC zone for 7 years.</p>
      </div>
      <div>
        <p class="eyebrow">Secondary zone</p>
        <h2 style="font-size:1.4rem;">North suburban ring</h2>
        <p class="section-lede">Lower-competition towns with active renovation cycles and strong school-driven demand.</p>
        <div class="chip-group">
          <span class="chip chip-secondary">Stoneham</span>
          <span class="chip chip-secondary">Burlington</span>
          <span class="chip chip-secondary">Wilmington</span>
          <span class="chip chip-secondary">Reading</span>
        </div>
        <p class="area-note">Not seeing your town? <a href="#estimate" style="color:var(--gold-deep);font-weight:600;">Ask us</a> — we may still be able to help.</p>
      </div>
    </div>
  </section>

  <!-- ===== ESTIMATE FORM ===== -->
  <section class="estimate-band" id="estimate">
    <div class="wrap estimate-grid">
      <div class="estimate-info">
        <p class="eyebrow">Get started</p>
        <h2>Tell us about your unit — we handle the building logistics.</h2>
        <p class="section-lede">A few details now means a same-day, line-item estimate with no obligation.</p>
        <div class="estimate-stats">
          <div class="estimate-stat">
            <div class="num">5 min</div>
            <p><strong>Fast acknowledgment</strong>Every inquiry gets a text confirmation within 5 minutes.</p>
          </div>
          <div class="estimate-stat">
            <div class="num">1 hr</div>
            <p><strong>Personal callback</strong>We follow up by phone within the hour to schedule your video walkthrough.</p>
          </div>
          <div class="estimate-stat">
            <div class="num">3</div>
            <p><strong>Good, better, best</strong>Every proposal includes three options, so you choose what fits your project and budget.</p>
          </div>
        </div>
      </div>

      <MultiStepForm />
    </div>
  </section>

  <!-- ===== TIERS / CLOSE ===== -->
  <section class="close-cta" id="tiers">
    <div class="wrap">
      <p class="eyebrow">Trusted by condo owners across the ICC zone</p>
      <h2>Every estimate comes in three options.</h2>
      <p class="tiers-sub">So you're never stuck choosing between "do it cheap" and "do it right." Pick the tier that fits your budget — and upgrade only what matters.</p>
      <div class="tiers-grid">
        <div class="tier-card">
          <div class="tier-name">Good</div>
          <h3>Refresh the finish</h3>
          <p>Spray existing cabinet doors and boxes in your chosen color — the core factory-grade transformation.</p>
        </div>
        <div class="tier-card best">
          <div class="tier-name">Better</div>
          <h3>Finish + hardware</h3>
          <p>Everything in Good, plus new soft-close hinges and updated hardware for a complete refresh.</p>
        </div>
        <div class="tier-card">
          <div class="tier-name">Best</div>
          <h3>Full unit kitchen</h3>
          <p>Everything in Better, plus interior shelving refresh and matching island or pantry cabinetry.</p>
        </div>
      </div>
      <div class="tiers-footer">
        <a class="btn btn-gold" href="#estimate" data-ph-event="cta_clicked" data-ph-label="tiers_get_estimate">Get my free video estimate</a>
        <p class="tiers-note">Every tier includes: zero lobby or hallway staging, low-VOC materials only, same-day cleanup, and a certificate of insurance for your HOA.</p>
        <div class="tiers-links">
          <a href="/financing/">Ask about financing →</a>
          <span style="color:rgba(247,243,234,0.25)">·</span>
          <a href="/guarantee/">Workmanship guarantee →</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ── Condo card ──────────────────────────────────── */
  .condo-strip {
    background: var(--bone-deep);
    border-bottom: 1px solid var(--line);
    padding: clamp(24px, 3vw, 40px) 0;
  }
  .condo-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(32px, 3.5vw, 52px);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .condo-strip-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 3vw, 44px);
  }
  .condo-strip-item {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    font-size: 15px;
    font-weight: 500;
    color: var(--forest);
    line-height: 1.5;
  }
  .condo-strip-item svg {
    width: 22px;
    height: 22px;
    color: var(--gold-deep);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .condo-card-sub {
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    font-weight: 500;
    color: var(--forest);
    line-height: 1.45;
    border-top: 1px solid var(--line);
    padding-top: var(--sp-4);
    letter-spacing: -0.01em;
    margin: 0;
  }

  /* ── Section: services ───────────────────────────── */
  .section-lede-center {
    max-width: 56ch;
    margin: var(--sp-3) auto 0;
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    text-align: center;
  }
  .section-link {
    display: inline-block;
    margin-top: var(--sp-5);
    text-align: center;
  }

  /* ── Area section ────────────────────────────────── */
  .area-section { background: var(--bone-deep); }
  .area-section a.chip { text-decoration: none; transition: opacity 0.15s; }
  .area-section a.chip:hover { opacity: 0.82; }
  .area-section h2 { margin-bottom: var(--sp-3); }

  /* ── Process link ────────────────────────────────── */
  .process-link-row {
    text-align: center;
    margin-top: var(--sp-6);
  }

  /* ── Gallery link ────────────────────────────────── */
  .gallery-link-row {
    text-align: center;
    margin-top: var(--sp-5);
  }

  /* ── Tiers ───────────────────────────────────────── */
  .tiers-sub {
    font-size: 1.05rem;
    color: rgba(247, 243, 234, 0.6);
    max-width: 52ch;
    margin: var(--sp-3) auto var(--sp-6);
    line-height: 1.7;
    text-align: center;
  }
  .tiers-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }
  .tiers-note {
    font-size: 13px;
    color: rgba(247, 243, 234, 0.5);
    max-width: 56ch;
    text-align: center;
    line-height: 1.7;
    letter-spacing: 0.01em;
  }
  .tiers-links {
    display: flex;
    gap: var(--sp-4);
    align-items: center;
    font-size: 13px;
  }
  .tiers-links a {
    color: rgba(247, 243, 234, 0.55);
    text-decoration: none;
    transition: color 0.15s;
    letter-spacing: 0.01em;
  }
  .tiers-links a:hover { color: var(--bone); }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 900px) {
    .condo-strip-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .condo-strip-grid { grid-template-columns: 1fr; }
    .tiers-links { flex-direction: column; gap: var(--sp-2); }
  }
</style>

<script>
  // Gallery filter
  (function () {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.gallery-item');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.getAttribute('data-filter') ?? 'all';
        items.forEach((item) => {
          const cats = item.getAttribute('data-cat') ?? '';
          if (filter === 'all' || cats.split(' ').includes(filter)) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });
  })();
</script>
