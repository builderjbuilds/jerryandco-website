<script>
  // Before/after slider
  (function () {
    const range = document.getElementById('baRange') as HTMLInputElement | null;
    const before = document.getElementById('baBefore');
    const handle = document.getElementById('baHandle');
    if (!range || !before || !handle) return;
    function update() {
      const v = range!.value;
      (before as HTMLElement).style.clipPath = `inset(0 ${100 - Number(v)}% 0 0)`;
      (handle as HTMLElement).style.left = v + '%';
    }
    range.addEventListener('input', update);
    update();
  })();

  // Gallery filter
  (function () {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.gallery-item');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.getAttribute('data-filter') ?? 'all';
        items.forEach((item) => {
          const cats = item.getAttribute('data-cat') ?? '';
          if (filter === 'all' || cats.split(' ').includes(filter)) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });
  })();

  // Estimate form submission
  (function () {
    const form = document.getElementById('estimateForm');
    const intro = document.getElementById('formIntro');
    const success = document.getElementById('formSuccess');
    if (!form || !intro || !success) return;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      (intro as HTMLElement).style.display = 'none';
      success.classList.add('show');
    });
  })();
</script>
