const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
  "name": "Jerry & Co. Home Improvement LLC",
  "description": "Factory-grade cabinet refinishing and bathroom refresh for condo owners across Greater Boston — built around your building's rules, your neighbors, and your timeline.",
  "url": "https://www.jerryandcohomeservices.com",
  "telephone": "(347) 602-6801",
  "email": "jerry@jerryandcohomeservices.com",
  "founder": {
    "@type": "Person",
    "name": "Jeremiah Ugbine"
  },
  "foundingDate": "2019-04-10",
  "areaServed": [
    "Medford, MA", "Malden, MA", "Everett, MA", "Arlington, MA",
    "Somerville, MA", "Cambridge, MA", "Woburn, MA", "Winchester, MA"
  ],
  "sameAs": [
    "https://www.instagram.com/improvewithjerryandco",
    "https://www.tiktok.com/@improvewithjerryandco",
    "https://www.youtube.com/@improvewithjerryandco",
    "https://www.facebook.com/improvewithjerryandco",
    "https://www.pinterest.com/improvewithjerryandco"
  ],
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "name": "Massachusetts Home Improvement Contractor Registration",
    "identifier": "MA HIC #208336"
